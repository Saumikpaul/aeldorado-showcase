# ═══════════════════════════════════════════════════
#  Aeldorado API — Environment Variables
#  by Solanacy Technologies
# ═══════════════════════════════════════════════════

# ── Firebase Admin SDK (server-side service account JSON) ───────────────────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"aeldorado-agentic-era",...}

# ── Firestore Database ID ───────────────────────────────────────────────────
FIRESTORE_DATABASE_ID=aeldorado-agentic-era

# ── Server Configuration ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── URLs ────────────────────────────────────────────────────────────────────
# Used for Cashfree order notify_url and return_url generation
API_BASE_URL=https://api.aeldorado.solanacy.in
FRONTEND_URL=https://aeldorado.solanacy.in

# ── Live Search (SearXNG, self-hosted) ──────────────────────────────────────
# Our own solanacy-searxng instance on Render. Primary source for
# core/live-search.js; falls back to direct Google/DuckDuckGo scraping if
# this is unreachable or returns nothing. See solanacy-searxng repo README.
SEARXNG_BASE_URL=https://solanacy-searxng.onrender.com

# ── Cashfree Payment Gateway ────────────────────────────────────────────────
# Get from: merchant.cashfree.com → Developers → API Keys
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here

# Environment: "production" or "sandbox"
CASHFREE_ENV=production

# Webhook endpoint to register in Cashfree dashboard:
#   https://api.aeldorado.solanacy.in/v1/billing/webhook
# Webhook signature is verified using CASHFREE_SECRET_KEY (no separate secret needed)

# ── Self-Ping (keeps Render free tier alive) ────────────────────────────────
PING_URL=https://api.aeldorado.solanacy.in
